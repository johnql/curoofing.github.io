# Supabase — https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx   # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...                     # service role key (used by upload script)
SUPABASE_ANON_KEY=your-anon-public-key                    # paste directly into admin.html lines 155-156 (not a Vercel var)

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # Your Twilio phone number
TWILIO_TO_NUMBER=+1XXXXXXXXXX    # Salesperson's mobile number

# Gmail — used to send confirmation emails to customers
# 1. Enable 2-Step Verification on the Gmail account
# 2. Go to Google Account → Security → App passwords → create one for "Mail"
# 3. Paste the 16-character App Password below (no spaces)
GMAIL_USER=curoofing.ca@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# HERE Geocoding API — https://developer.here.com → Projects → your project → API Keys
# Used server-side only in api/here-*.js. Never expose in browser.
HERE_API_KEY=your-here-api-key

# Microsoft Building Footprints tiles (Supabase Storage — public bucket)
# One-time setup:
#   1. Supabase dashboard → Storage → create bucket "msft-tiles" (public)
#   2. Set SUPABASE_SERVICE_ROLE_KEY above
#   3. Run: node scripts/tile-msft.js <GTA.geojson> ./msft-tiles-02
#   4. Run: node scripts/upload-tiles.js ./msft-tiles-02
#   5. MSFT_TILES_BASE_URL is written to .env.local automatically after upload
MSFT_TILES_BASE_URL=https://your-project-id.supabase.co/storage/v1/object/public/msft-tiles
